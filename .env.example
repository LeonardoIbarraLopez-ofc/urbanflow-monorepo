# .env.example — Variables de entorno unificadas para UrbanFlow Monorepo.
# Copiar a .env y completar con credenciales reales (nunca subir .env a git).

# ============================================================
# EVENT STREAMING — Upstash Kafka (Free-Tier)
# ============================================================
UPSTASH_KAFKA_BROKERS=your-broker.upstash.io:9092
UPSTASH_KAFKA_USERNAME=your-upstash-username
UPSTASH_KAFKA_PASSWORD=your-upstash-password

# Tópicos Kafka
KAFKA_TOPIC_GPS=telemetry.raw.gps
KAFKA_TOPIC_CONGESTION=traffic.congestion.predicted
KAFKA_TOPIC_REROUTE=bus.reroute.command
KAFKA_TOPIC_PAYMENT=payment.transaction

# ============================================================
# GRAPH DATABASE — Neo4j AuraDB (Free-Tier)
# ============================================================
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-auradb-password

# ============================================================
# RELATIONAL DB — Supabase / PostgreSQL (Free-Tier)
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Para desarrollo local (TimescaleDB en Docker)
POSTGRES_USER=urbanflow
POSTGRES_PASSWORD=urbanflow_dev
POSTGRES_DB=urbanflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================================
# DOCUMENT DB — MongoDB Atlas M0 (Free-Tier)
# ============================================================
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/urbanflow?retryWrites=true&w=majority

# Para desarrollo local (MongoDB en Docker)
MONGO_USERNAME=urbanflow
MONGO_PASSWORD=urbanflow_dev
MONGO_HOST=localhost
MONGO_PORT=27017

# ============================================================
# CACHE — Upstash Redis (Free-Tier)
# ============================================================
UPSTASH_REDIS_URL=rediss://your-redis.upstash.io:6380
UPSTASH_REDIS_TOKEN=your-redis-token

# Para desarrollo local (Redis en Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=urbanflow_dev

# ============================================================
# STORAGE — Supabase Storage (Data Lake Parquet)
# ============================================================
SUPABASE_STORAGE_BUCKET=urbanflow-datalake

# ============================================================
# MICROSERVICIOS — Puertos internos
# ============================================================
TELEMETRY_HTTP_PORT=8080
TELEMETRY_UDP_PORT=9001
PAYMENT_PORT=3000
ROUTING_PORT=8000
TRAFFIC_BRIDGE_PORT=3000
MOBILITY_PORT=3000
PREDICTOR_PORT=8001
NOTIFICATION_PORT=3000

# ============================================================
# SEMÁFOROS NTCIP — Mapa IP de controladores físicos
# ============================================================
# Formato: ID_SEMAFORO=IP:PUERTO_UDP
NTCIP_CONTROLLER_MAP={"TL001":"192.168.10.1:10001","TL002":"192.168.10.2:10001"}

# ============================================================
# ENTORNO
# ============================================================
NODE_ENV=development
PYTHON_ENV=development
GO_ENV=development
