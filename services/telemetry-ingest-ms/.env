# Variables de entorno para telemetry-ingest-ms
TELEMETRY_HTTP_PORT=8080
TELEMETRY_UDP_PORT=9001

# Upstash Kafka (Completar con credenciales reales en producción)
UPSTASH_KAFKA_BROKERS=your-broker.upstash.io:9092
UPSTASH_KAFKA_USERNAME=your-upstash-username
UPSTASH_KAFKA_PASSWORD=your-upstash-password

# Tópico Kafka
KAFKA_TOPIC_GPS=telemetry.raw.gps
